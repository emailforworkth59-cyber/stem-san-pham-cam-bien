<!DOCTYPE html>
<html>
<head>
    <title>IoT Auth</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #e9ecef; display: flex; align-items: center; height: 100vh; }
        .auth-box { max-width: 400px; margin: auto; }
    </style>
</head>
<body>
<div class="container auth-box">
    <div class="card shadow-lg border-0 p-4">
        <h2 class="text-center text-success mb-4">Hệ Thống 11A7</h2>
        
        <% if (error) { %> <div class="alert alert-danger py-2 small"><%= error %></div> <% } %>
        <% if (success) { %> <div class="alert alert-success py-2 small"><%= success %></div> <% } %>

        <ul class="nav nav-tabs mb-4 justify-content-center" id="authTab">
            <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#login">Đăng nhập</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#reg">Đăng ký</button></li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="login">
                <form action="/login" method="POST">
                    <input type="text" name="username" class="form-control mb-3" placeholder="Tên đăng nhập" required>
                    <input type="password" name="password" class="form-control mb-3" placeholder="Mật khẩu" required>
                    <button class="btn btn-success w-100">Đăng Nhập</button>
                </form>
            </div>
            <div class="tab-pane fade" id="reg">
                <form action="/register" method="POST">
                    <input type="text" name="username" class="form-control mb-3" placeholder="Tên đăng nhập mới" required>
                    <input type="password" name="password" class="form-control mb-3" placeholder="Mật khẩu mới" required>
                    <button class="btn btn-primary w-100">Tạo Tài Khoản</button>
                </form>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>