<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Thống IoT 11A7</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .card-soil { transition: transform 0.2s; border-radius: 15px; }
        .card-soil:hover { transform: scale(1.02); }
        .status-badge { font-size: 1.1rem; }
    </style>
</head>
<body>
    <div class="container py-5">
        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold text-success">🌱 Trạm Giám Sát Độ Ẩm 11A7</h1>
            <p class="text-muted">Hệ thống quản lý cây trồng đa người dùng</p>
        </div>

        <div class="row">
            <% if (plants.length === 0) { %>
                <div class="col-12 text-center">
                    <p class="alert alert-info">Chưa có dữ liệu thiết bị. Hãy gửi dữ liệu từ ESP32!</p>
                </div>
            <% } %>

            <% plants.forEach(plant => { %>
                <div class="col-md-4 mb-4">
                    <div class="card shadow card-soil">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title fw-bold"><%= plant.plant_name %></h5>
                                <span class="badge bg-secondary">ID: <%= plant.device_id %></span>
                            </div>
                            
                            <hr>

                            <div class="text-center my-4">
                                <h2 class="display-3 fw-bold mb-0">
                                    <%= plant.soil_percent !== null ? plant.soil_percent : '--' %><small class="h4">%</small>
                                </h2>

                                <% 
                                    let status = "Đang chờ dữ liệu...";
                                    let colorClass = "text-secondary";
                                    let bgClass = "bg-secondary";

                                    if (plant.soil_percent !== null) {
                                        if (plant.soil_percent < plant.min_threshold) {
                                            status = "🔴 Quá khô";
                                            colorClass = "text-danger";
                                            bgClass = "bg-danger";
                                        } else if (plant.soil_percent > plant.max_threshold) {
                                            status = "🟡 Quá ướt";
                                            colorClass = "text-warning";
                                            bgClass = "bg-warning";
                                        } else {
                                            status = "🟢 Ổn định";
                                            colorClass = "text-success";
                                            bgClass = "bg-success";
                                        }
                                    }
                                %>
                                <div class="status-badge fw-bold mt-2 <%= colorClass %>">
                                    <%= status %>
                                </div>
                            </div>

                            <div class="bg-light p-2 rounded text-center small mb-3">
                                <b>Khoảng an toàn:</b> <%= plant.min_threshold %>% - <%= plant.max_threshold %>%
                            </div>

                            <p class="card-text text-muted small">
                                <i class="bi bi-clock"></i> Cập nhật: <%= plant.timestamp ? new Date(plant.timestamp).toLocaleString('vi-VN') : 'Chưa có' %>
                            </p>

                            <form action="/update-threshold" method="POST" class="mt-3">
                                <input type="hidden" name="plant_id" value="<%= plant.id %>">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <label class="x-small">Min (%)</label>
                                        <input type="number" name="min_threshold" class="form-control form-control-sm" value="<%= plant.min_threshold %>">
                                    </div>
                                    <div class="col-6">
                                        <label class="x-small">Max (%)</label>
                                        <input type="number" name="max_threshold" class="form-control form-control-sm" value="<%= plant.max_threshold %>">
                                    </div>
                                    <div class="col-12 mt-2">
                                        <button class="btn btn-outline-primary btn-sm w-100">Cập nhật ngưỡng</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</body>
</html>