<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trang Chủ - Hệ Thống Giám Sát IoT</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/dashbroad.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>
  <body>

    <!-- ── Navbar ── -->
    <nav class="navbar bg-white py-3 shadow-sm">
      <div class="container max-w-720">
        <span class="navbar-brand mb-0">
          <div class="brand-icon">
            <i class="fa-solid fa-leaf"></i>
          </div>
          Nông Trại Thông Minh
        </span>
        <a href="/logout" class="logout-link">
          <i class="fa-solid fa-arrow-right-from-bracket"></i>Đăng xuất
        </a>
      </div>
    </nav>

    <!-- ── Main Content ── -->
    <div class="container max-w-720 mb-5">

      <!-- Page Header -->
      <div class="page-header">
        <div>
          <h4 class="fw-bold mb-2">Thiết Bị Của Tôi</h4>
          <span class="station-count-badge">
            Đang giám sát <%= plants ? plants.length : 0 %> trạm
          </span>
        </div>
        <a href="/plants/select" class="btn btn-submit shadow-sm">
          <i class="fa-solid fa-plus"></i> Thêm Trạm
        </a>
      </div>

      <!-- ── Station List ── -->
      <% if (plants && plants.length > 0) { %>
        <div class="row g-3">
          <% plants.forEach(function(plant) {
            const pct = plant.soil_percent;
            const hasData = pct !== null && pct !== undefined;
            const isLow  = hasData && pct < plant.min_threshold;
            const isHigh = hasData && pct > plant.max_threshold;
            const isOk   = hasData && !isLow && !isHigh;
            const barPct = hasData ? Math.min(100, Math.max(0, pct)) : 0;
            const minBarLeft = Math.min(100, Math.max(0, plant.min_threshold));
            const maxBarLeft = Math.min(100, Math.max(0, plant.max_threshold));
          %>
          <div class="col-12">
            <div class="station-card">
              <div class="row g-0">

                <!-- Image -->
                <div class="col-4 station-img-col">
                  <img src="<%= plant.image_url %>" alt="<%= plant.plant_name %>" loading="lazy" />
                  <div class="img-overlay"></div>
                </div>

                <!-- Body -->
                <div class="col-8">
                  <div class="station-body">

                    <!-- Header -->
                    <div class="station-header">
                      <div>
                        <div class="station-name"><%= plant.plant_name %></div>
                        <div class="station-meta"><%= plant.device_id %> · <%= plant.type_name %></div>
                      </div>
                      <div class="station-actions">
                        <span class="badge-online">Online</span>
                        <form action="/plants/delete/<%= plant.id %>" method="POST"
                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa trạm này? Toàn bộ dữ liệu sẽ bị mất vĩnh viễn.');"
                          style="margin:0;">
                          <button type="submit" class="btn-delete" title="Xóa trạm">
                            <i class="fa-solid fa-trash"></i>
                          </button>
                        </form>
                      </div>
                    </div>

                    <!-- Metrics -->
                    <div class="metrics-row">
                      <div class="metric-tile">
                        <div class="metric-tile-label">Độ ẩm đất</div>
                        <div class="metric-tile-val
                          <%= !hasData ? 'val-dash' : isLow ? 'val-warn' : isHigh ? 'val-caution' : 'val-ok' %>"
                          id="moisture-val-<%= plant.device_id %>">
                          <%= hasData ? pct : '—' %>
                          <% if (hasData) { %><span style="font-size:0.75rem;opacity:0.6;">%</span><% } %>
                        </div>
                        <div class="metric-tile-time" id="time-<%= plant.device_id %>">
                          <%= plant.timestamp ? new Date(plant.timestamp).toLocaleString("vi-VN") : 'Chưa có dữ liệu' %>
                        </div>
                      </div>
                      <div class="metric-tile">
                        <div class="metric-tile-label">Ngưỡng cài</div>
                        <div style="display:flex;align-items:baseline;gap:4px;margin-top:2px;">
                          <span style="font-size:0.68rem;color:var(--neutral-500);font-weight:600;">MIN</span>
                          <span style="font-size:1rem;font-weight:600;font-family:'DM Mono',monospace;color:var(--green-700);"><%= plant.min_threshold %>%</span>
                          <span style="font-size:0.68rem;color:var(--neutral-300,#d1d5db);">·</span>
                          <span style="font-size:0.68rem;color:var(--neutral-500);font-weight:600;">MAX</span>
                          <span style="font-size:1rem;font-weight:600;font-family:'DM Mono',monospace;color:var(--amber-600);"><%= plant.max_threshold %>%</span>
                        </div>
                        <div class="metric-tile-sub">Phạm vi hoạt động</div>
                      </div>
                    </div>

                    <!-- Moisture bar -->
                    <div class="moisture-bar-wrap">
                      <div class="moisture-bar-header">
                        <span class="moisture-bar-label">Mức độ ẩm</span>
                        <span class="moisture-bar-pct"><%= hasData ? pct + '%' : 'N/A' %></span>
                      </div>
                      <div class="moisture-track">
                        <!-- Zone markers -->
                        <div class="moisture-zone-min" style="left:<%= minBarLeft %>%;"></div>
                        <div class="moisture-zone-max" style="left:<%= maxBarLeft %>%;"></div>
                        <!-- Fill -->
                        <div class="moisture-fill <%= isLow ? 'fill-warn' : isHigh ? 'fill-caution' : '' %>"
                          style="width:<%= barPct %>%;"></div>
                      </div>
                    </div>

                    <!-- Status Banner -->
                    <div id="status-<%= plant.device_id %>"
                      class="status-banner
                        <%= !hasData ? 'status-no-data' : isLow ? 'status-danger' : isHigh ? 'status-warning' : 'status-success' %>">
                      <% if (!hasData) { %>
                        <i class="fa-solid fa-circle-question fa-xs"></i> Chưa có dữ liệu
                      <% } else if (isLow) { %>
                        <i class="fa-solid fa-droplet fa-xs"></i> Cần tưới nước gấp!
                      <% } else if (isHigh) { %>
                        <i class="fa-solid fa-triangle-exclamation fa-xs"></i> Quá ẩm — ngưng tưới
                      <% } else { %>
                        <i class="fa-solid fa-circle-check fa-xs"></i> Đất tốt — bình thường
                      <% } %>
                    </div>

                    <!-- Threshold form -->
                    <form action="/plants/update-threshold/<%= plant.id %>" method="POST">
                      <div class="threshold-row">
                        <div class="threshold-field">
                          <span class="threshold-lbl">Min</span>
                          <input type="number" name="min_threshold" class="threshold-input"
                            value="<%= plant.min_threshold %>" min="0" max="100" />
                          <span class="threshold-unit">%</span>
                        </div>
                        <div class="threshold-field">
                          <span class="threshold-lbl">Max</span>
                          <input type="number" name="max_threshold" class="threshold-input"
                            value="<%= plant.max_threshold %>" min="0" max="100" />
                          <span class="threshold-unit">%</span>
                        </div>
                        <button type="submit" class="btn btn-save-threshold">Lưu</button>
                      </div>
                    </form>

                    <!-- Chart toggle -->
                    <button class="btn-chart-toggle" type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#collapseChart-<%= plant.device_id %>"
                      aria-expanded="false">
                      <i class="fa-solid fa-chart-line"></i> Xem Biểu Đồ Độ Ẩm
                    </button>

                    <div class="collapse" id="collapseChart-<%= plant.device_id %>">
                      <div class="chart-collapse-body">
                        <canvas id="chart-<%= plant.device_id %>" width="400" height="180"></canvas>
                      </div>
                    </div>

                  </div><!-- /station-body -->
                </div><!-- /col-8 -->

              </div><!-- /row -->
            </div><!-- /station-card -->
          </div><!-- /col-12 -->
          <% }); %>
        </div>

      <% } else { %>
        <!-- Empty State -->
        <div class="empty-state-card">
          <div class="empty-state-icon">
            <i class="fa-solid fa-seedling"></i>
          </div>
          <h5>Chưa có trạm nào</h5>
          <p>Bạn chưa cấu hình trạm giám sát nào cho khu vườn của mình.</p>
          <a href="/plants/select" class="btn btn-submit px-4">
            <i class="fa-solid fa-plus me-1"></i> Bắt đầu thêm trạm đầu tiên
          </a>
        </div>
      <% } %>

    </div><!-- /container -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/updateData.js"></script>
  </body>
</html>