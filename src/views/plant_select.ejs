<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thêm Trạm Giám Sát - Hệ Thống IoT</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/dashbroad.css" />
  </head>
  <body>
    <nav class="navbar bg-white py-3 mb-4 shadow-sm">
      <div class="container d-flex justify-content-between align-items-center max-w-720">
        <a href="/" class="text-decoration-none text-secondary"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a>
        <span class="navbar-brand mb-0 h5 fw-bold text-dark">Thêm Trạm Mới</span>
        <div style="width: 80px"></div>
      </div>
    </nav>

    <div class="container max-w-720">
      <div class="mb-4">
        <h4 class="fw-bold">Chọn hồ sơ thực vật</h4>
        <p class="text-secondary">Hệ thống sẽ đồng bộ ngưỡng độ ẩm theo chuẩn nông nghiệp.</p>
      </div>

      <form action="/plants/add" method="POST">
        <div class="row g-3 mb-5">
          <% if (catalogs && catalogs.length > 0) { %>
            <% catalogs.forEach(function(item, index) { %>
              <div class="col-6 col-md-4">
                <label class="plant-card <%= index === 0 ? 'selected' : '' %>">
                  <input type="radio" name="catalog_id" value="<%= item.id %>" class="d-none" <%= index === 0 ? 'checked' : '' %> />
                  <div class="check-badge"><i class="fa-solid fa-check"></i></div>
                  <img src="<%= item.image_url %>" alt="<%= item.type_name %>" class="plant-image">
                  <div class="plant-info">
                    <div class="fw-bold mb-1"><%= item.type_name %></div>
                    <div class="text-muted" style="font-size: 0.85rem;">
                      <i class="fa-solid fa-droplet me-1" style="color: #4299e1;"></i>
                      <%= item.default_min %>% - <%= item.default_max %>%
                    </div>
                  </div>
                </label>
              </div>
            <% }); %>
          <% } else { %>
            <div class="col-12 text-center py-4">
              <p class="text-secondary">Chưa có danh mục cây trồng.</p>
            </div>
          <% } %>
        </div>

        <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px;">
          <div class="card-body p-4">
            <label class="form-label fw-bold mb-2">Định danh thiết bị (Device ID)</label>
            <input type="text" name="device_id" class="form-control form-control-lg" placeholder="VD: ESP01" required autocomplete="off" />
            <small class="text-secondary mt-2 d-block">Nhập mã được in trên vỏ hộp mạch điều khiển ESP32.</small>
          </div>
        </div>

        <button type="submit" class="btn btn-submit w-100 shadow-sm">
          <i class="fa-solid fa-microchip me-2"></i>KÍCH HOẠT TRẠM GIÁM SÁT
        </button>
      </form>
    </div>

    <script>
      // Xu ly logic hien thi giao dien khi chon the
      const cards = document.querySelectorAll(".plant-card");
      const radios = document.querySelectorAll('input[type="radio"]');

      cards.forEach((card, index) => {
        card.addEventListener("click", function () {
          cards.forEach((c) => c.classList.remove("selected"));
          this.classList.add("selected");
          radios[index].checked = true;
        });
      });
    </script>
  </body>
</html>